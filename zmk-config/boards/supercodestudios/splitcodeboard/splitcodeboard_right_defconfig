# This file was generated from a template. Edit it to match your keyboard.
# See https://docs.zephyrproject.org/4.1.0/hardware/porting/board_porting.html#write-kconfig-files
# for more information.

# Enable GPIO
CONFIG_GPIO=y

# Use pinctrl
CONFIG_PINCTRL=y

# Enable I2C for MCP23017 matrix expander
CONFIG_I2C=y

# Polling mode is the most reliable starting point with GPIO expanders
CONFIG_ZMK_KSCAN_MATRIX_POLLING=y
CONFIG_ZMK_KSCAN_DIRECT_POLLING=y

# Rotary encoder support (right side)
CONFIG_EC11=y
CONFIG_EC11_TRIGGER_GLOBAL_THREAD=y

# Enable ZMK outputs
CONFIG_ZMK_BLE=y
# CONFIG_ZMK_USB is not set

